.v3-font-headline-1 { font-family: "Inter Tight", sans-serif; font-optical-sizing: auto; font-size: 24px; font-weight: 600; line-height: 32px; }

.v3-font-headline-2 { font-family: "Inter Tight", sans-serif; font-optical-sizing: auto; font-size: 16px; font-weight: 600; line-height: 24px; }

.v3-font-label { font-family: Inter, sans-serif; font-optical-sizing: auto; font-size: 12px; font-weight: 400; line-height: 18px; }

.v3-font-label-thin { font-family: Inter, sans-serif; font-optical-sizing: auto; font-size: 12px; font-weight: 400; line-height: 16px; }

.v3-font-body { font-family: Inter, sans-serif; font-optical-sizing: auto; font-size: 14px; font-weight: 400; line-height: 21px; }

.v3-font-body-medium { font-family: Inter, sans-serif; font-optical-sizing: auto; font-size: 14px; font-weight: 500; line-height: 21px; }

html { font-family: Inter, sans-serif; font-optical-sizing: auto; font-size: 14px; font-weight: 400; line-height: 21px; -webkit-font-smoothing: antialiased; }

h1, h2, h3, h4, h5, h6 { margin: 0px; }

.light-theme, .dark-theme { scrollbar-color: var(--color-v3-outline) transparent; }

.makersuite-layout { display: flex; overflow: hidden; flex: 1 0 0%; }

.makersuite-layout .layout-wrapper { display: flex; flex-direction: column; height: 100%; width: 100%; overflow: hidden; }

.makersuite-layout .layout-main { flex: 1 0 0%; min-height: 0px; outline: none; overflow-x: hidden; width: 100%; }

html, body, body.light-theme, body.dark-theme { font-size: 14px; font-weight: 400; line-height: 20px; font-family: Inter, sans-serif; letter-spacing: normal; --mat-icon-button-touch-target-display: none; }

html .mat-mdc-icon-button.mat-mdc-button-base, body .mat-mdc-icon-button.mat-mdc-button-base, body.light-theme .mat-mdc-icon-button.mat-mdc-button-base, body.dark-theme .mat-mdc-icon-button.mat-mdc-button-base { --mdc-icon-button-state-layer-size: 40px; --mat-icon-button-state-layer-size: 40px; width: var(--mat-icon-button-state-layer-size); height: var(--mat-icon-button-state-layer-size); padding: 8px; }

html, body { height: 100%; margin: 0px; overflow: hidden; }

app-root { display: flex; flex-direction: column; flex-grow: 1; min-height: 0px; }

body { background-color: var(--color-v3-surface-container); color: var(--color-v3-text); display: flex; flex-direction: column; }

.light-theme ms-edit-function-declarations-dialog .entry-name .mat-mdc-form-field-subscript-wrapper, .light-theme ms-edit-function-declarations-dialog .entry-description .mat-mdc-form-field-subscript-wrapper { display: none; }

.light-theme ms-edit-function-declarations-dialog .entry-name input, .light-theme ms-edit-function-declarations-dialog .entry-description input { vertical-align: middle; }

.light-theme a { color: var(--color-v3-text-link); font-weight: 500; text-decoration: none; cursor: pointer; }

.light-theme b { font-weight: 500; }

.light-theme button { font-size: 14px; font-weight: 500; line-height: 20px; font-family: Inter, sans-serif; letter-spacing: normal; }

.dark-theme ms-edit-function-declarations-dialog .entry-name .mat-mdc-form-field-subscript-wrapper, .dark-theme ms-edit-function-declarations-dialog .entry-description .mat-mdc-form-field-subscript-wrapper { display: none; }

.dark-theme ms-edit-function-declarations-dialog .entry-name input, .dark-theme ms-edit-function-declarations-dialog .entry-description input { vertical-align: middle; }

.dark-theme a { color: var(--color-v3-text-link); font-weight: 500; text-decoration: none; cursor: pointer; }

.dark-theme b { font-weight: 500; }

.dark-theme button { font-size: 14px; font-weight: 500; line-height: 20px; font-family: Inter, sans-serif; letter-spacing: normal; }

.page-content-wrapper { align-items: center; display: flex; flex-direction: column; padding-left: 24px; padding-right: 24px; overflow: hidden auto; height: 100%; background-color: var(--color-v3-surface); }

@media screen and (max-width: 600px) {
  .page-content-wrapper { padding-left: 16px; padding-right: 16px; }
